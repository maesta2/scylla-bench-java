# Set default behavior to automatically normalize line endings
* text=auto

# Force LF for shell scripts to avoid "bad interpreter" errors on Linux/macOS
*.sh text eol=lf

# Force LF for other source files
*.java text eol=lf
*.xml text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.md text eol=lf
*.properties text eol=lf

# Binary files
*.jar binary
*.class binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary

