[core]
	repositoryformatversion = 0
	filemode = false
	bare = false
	logallrefupdates = true
	symlinks = false
	ignorecase = true
[lfs]
	repositoryformatversion = 0
[remote "origin"]
	url = git@github.com:maesta2/scylla-bench-java.git
	fetch = +refs/heads/*:refs/remotes/origin/*
[branch "main"]
	remote = origin
	merge = refs/heads/main
[gitflow "branch"]
	master = main
	develop = dev
[gitflow "prefix"]
	feature = feature/
	release = release/
	hotfix = hotfix/
	versiontag = 
	bugfix = bugfix/
	support = support/
[gitflow "path"]
	hooks = G:/Git/scylla-bench-java/.git/hooks
[branch "dev"]
	vscode-merge-base = origin/main
